# docker-compose.override.yml
# Este arquivo é automaticamente carregado pelo docker-compose se existir
# Use para customizações locais sem alterar docker-compose.yml
# 
# Exemplo de uso:
# 1. Copiar este arquivo para docker-compose.override.yml
# 2. Editar conforme necessário
# 3. docker-compose up (já vai usar as customizações)
#
# NÃO COMMITAR ESTE ARQUIVO (já está em .gitignore)

version: '3.8'

services:
  app:
    # Exemplo: adicionar variáveis de ambiente customizadas
    environment:
      - DEBUG=1
      - LOG_LEVEL=debug
    
    # Exemplo: expor portas adicionais
    ports:
      - "9000:9000"  # Debug port
    
    # Exemplo: adicionar volumes customizados
    # volumes:
    #   - ./src:/app/src  # Hot-reload para desenvolvimento
    #   - ./config:/app/config
    
    # Exemplo: alterar comando
    # command: npm run dev

  # Exemplo: adicionar serviço PostgreSQL local
  # postgres:
  #   image: postgres:15
  #   environment:
  #     POSTGRES_USER: app
  #     POSTGRES_PASSWORD: localpass
