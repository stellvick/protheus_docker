# Timezone
TZ=America/Sao_Paulo

# Ambiente
NODE_ENV=production
ENVIRONMENT=production

# Logging
LOG_LEVEL=info

# Aplicação
PORT=3000
HOST=0.0.0.0

# SSL/TLS
SSL_CERT_PATH=/app/ssl/certs/cert.pem
SSL_KEY_PATH=/app/ssl/private/key.pem

# Banco de dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASSWORD=change_me

# Redis
REDIS_URL=redis://redis:6379
